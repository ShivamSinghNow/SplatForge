# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# --- MongoDB Atlas (replay buffer / trajectory store) ---
# Unset -> the local JsonlRepository (runs/*.jsonl) is used instead.
MONGODB_URI=
MONGODB_DATABASE=splatforge

# --- Voyage AI (embeddings for failure vector search) ---
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-3-lite

# --- Google Gemini (curriculum generator + VLM critic) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_CURRICULUM_MODEL=gemini-2.5-flash
GEMINI_VLM_MODEL=gemini-2.5-flash

# --- DigitalOcean H100 droplet (training) ---
DO_DROPLET_HOST=
DO_SSH_KEY_PATH=

# --- Sim / success signal ---
LIFT_THRESHOLD_M=0.10
