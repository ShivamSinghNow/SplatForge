# Required when you want cloud episode logging.
MONGODB_URI=
MONGODB_DATABASE=splatforge

# Required for Voyage AI failure-note embeddings and vector search.
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-3-lite

# Required when you want Gemini to participate in the critic council.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_CURRICULUM_MODEL=gemini-2.5-flash
GEMINI_VLM_MODEL=gemini-2.5-flash

# Optional: add this once MiniMax is wired as a second multimodal critic.
MINIMAX_API_KEY=

# Optional: future local/hosted model endpoint for Gemma/Modular.
GEMMA_ENDPOINT=
MONJU_ENDPOINT=

# Required later for the Isaac GPU backend on Linux/NVIDIA machines.
ISAAC_SIM_ROOT=
ISAAC_SIM_PYTHON=
