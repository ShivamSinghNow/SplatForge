# ChromaDB / vector store (generated data — not versioned)
chroma_db/
*.sqlite3

# Runtime outputs / generated scene assets
runs/
demo/assets/*
!demo/assets/
!demo/assets/README.md

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.python-version

# Environment / secrets
.env
.env.*
!.env.example

# Node (in case of a JS/TS frontend later)
node_modules/
.next/
dist/
*.log

# Generated artifacts (loop runs + trained adapters)
runs/
adapters/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
.gstack/

# MuJoCo writes a log file at render time
MUJOCO_LOG.TXT

# Gaussian splat scans — large; drop your own in web/public/splats/.
# Keep the manifest and the placeholder.
web/public/splats/*
!web/public/splats/scenes.json
!web/public/splats/placeholder.splat
!web/public/splats/README.md
